# ============================================================
# 本番環境変数テンプレート
# このファイルを .env.production にコピーして実際の値を設定してください
# .env.production は .gitignore に含まれています（コミットしないこと）
# ============================================================

# サイト本番URL（末尾スラッシュなし）
VITE_SITE_URL=https://your-domain.com

# Strapi Cloud
VITE_STRAPI_API_URL=https://your-strapi-cloud-url.strapiapp.com
VITE_STRAPI_API_TOKEN=your_strapi_api_token_here

# Clerk（本番用キーを使用: pk_live_ から始まるキー）
VITE_CLERK_PUBLISHABLE_KEY=pk_live_your_clerk_publishable_key_here

# Shopify Storefront API
VITE_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=your_storefront_api_token_here
