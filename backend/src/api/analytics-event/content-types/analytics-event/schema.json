      "type": "string"
    },
    "replayState": {
      "type": "string"
    },
    "membershipStatus": {
      "type": "string"
    },
    "entitlementState": {
      "type": "string"
    },
    "subscriptionState": {
      "type": "string"
    },
    "billingState": {
      "type": "string"
    },
    "lifecycleStage": {
      "type": "string"
    },
    "sourceSection": {
      "type": "string"
    },
