    "contentType": {
      "type": "string"
    },
    "entityId": {
      "type": "string"
    },
    "entitySlug": {
      "type": "string"
    },
    "formType": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "userState": {
      "type": "enumeration",
      "enum": [
        "guest",
        "logged_in",
        "unknown"
      ],
      "default": "unknown"
