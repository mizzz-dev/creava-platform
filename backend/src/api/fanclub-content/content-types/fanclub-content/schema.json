{
  "kind": "collectionType",
  "collectionName": "fanclub_contents",
  "info": {
    "singularName": "fanclub-content",
    "pluralName": "fanclub-contents",
    "displayName": "Fanclub Post",
    "description": "Fan club exclusive content / ファンクラブ限定コンテンツ"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "publishAt": {
      "type": "datetime"
    },
    "limitedEndAt": {
      "type": "datetime"
    },
    "archiveVisibleForFC": {
      "type": "boolean",
      "default": false
    },
    "body": {
      "type": "richtext"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "diary",
        "exclusive",
        "qa",
        "behind_scenes",
        "teaser",
        "live_archive",
        "tips",
        "info"
      ],
      "default": "diary"
    },
    "thumbnail": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "accessStatus": {
      "type": "enumeration",
      "enum": [
        "public",
        "fc_only",
        "limited"
      ],
      "default": "fc_only",
      "required": true
    },
    "relatedProducts": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::store-product.store-product"
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "pickup": {
      "type": "boolean",
      "default": false
    },
    "memberBenefit": {
      "type": "text"
    },
    "membersOnlyNotice": {
      "type": "text"
    },
    "earlyAccess": {
      "type": "boolean",
      "default": false
    },
    "specialOffer": {
      "type": "text"
    },
    "campaignLabel": {
      "type": "string"
    },
    "heroCopy": {
      "type": "text"
    },
    "shortHighlight": {
      "type": "text"
    },
    "isTrending": {
      "type": "boolean",
      "default": false
    },
    "isLimited": {
      "type": "boolean",
      "default": false
    },
    "displayPriority": {
      "type": "integer",
      "default": 0
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    }
  }
}
